+				// the next `onChange` snapshot. No-op.
+				return;
+			}
+			setThemeState(next);
+			if (typeof window !== "undefined") {
+				try {
+					window.localStorage.setItem(STORAGE_KEY, next);
+				} catch {
+					// Ignore quota / private-mode failures.
+				}
+			}
+		},
+		[controlledByHub],
+	);
